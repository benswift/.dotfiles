#!/usr/bin/env bash

set -euo pipefail

# Find repo root
if ! repo_root=$(git rev-parse --show-toplevel 2>/dev/null); then
    echo "Error: not in a git repository"
    exit 1
fi

# Bridge repos that still use AGENTS.md into the shared CLAUDE.md convention.
if [[ ! -f "$repo_root/AGENTS.md" ]]; then
    echo "No AGENTS.md file found in repo root: $repo_root"
    exit 0
fi

if [[ -e "$repo_root/CLAUDE.md" && ! -L "$repo_root/CLAUDE.md" ]]; then
    echo "CLAUDE.md already exists and is not a symlink: $repo_root/CLAUDE.md"
    exit 0
fi

ln -sfn "$repo_root/AGENTS.md" "$repo_root/CLAUDE.md"
echo "Created symlink: $repo_root/CLAUDE.md -> AGENTS.md"

if [[ -L "$repo_root/codex.md" && "$(readlink "$repo_root/codex.md")" == "$repo_root/AGENTS.md" ]]; then
    rm "$repo_root/codex.md"
    echo "Removed obsolete symlink: $repo_root/codex.md"
fi

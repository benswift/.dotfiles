#!/usr/bin/env bash
#
# ts-cat --- print a file to stdout with tree-sitter syntax highlighting.
#
# Written for yazi's preview pane (see yazi/yazi.toml, which pipes it through
# piper.yazi), but it works as a standalone `cat` too. Unlike yazi's built-in
# previewer --- and unlike bat --- this understands language injections, so
# YAML frontmatter in a markdown file and the TypeScript fence at the top of
# an .astro component get highlighted as YAML and TypeScript.
#
# Highlighting is done by lumis (tree-sitter parsing with nvim-treesitter
# queries; https://lumis.sh), installed via mise. Its parsers are WASM files
# cached in ~/.local/share/lumis --- bin/lumis-parsers pre-fetches the common
# set, and lumis silently downloads any other parser on first use. A file it
# has no parser for is passed through as plain text, so no output-sniffing is
# needed to detect that case.
#
# Two constraints come from piper, and both are load-bearing:
#
#   1. Anything this script writes to stderr *replaces* the preview, so all
#      stderr is discarded.
#   2. piper kills us once it has read enough lines to fill the pane, so
#      exiting non-zero on SIGPIPE is normal and must not be treated as an
#      error.

set -uo pipefail

file="${1:-}"
[[ -n "$file" && -r "$file" ]] || exit 0

# Parsing a whole 100k-line file to render 40 visible lines is wasted work,
# and tree-sitter is error-tolerant enough that a truncated tail is harmless.
MAX_LINES="${TS_CAT_MAX_LINES:-5000}"

# Matches the theme Helix and zj-switch use.
THEME="${TS_CAT_THEME:-catppuccin_mocha}"

# lumis picks a language from the file extension (falling back to shebang).
# These are the cases where that lookup misses but an existing parser is the
# right answer anyway: .mdx is markdown-with-JSX, jsonc is JSON that the
# error-tolerant parser copes with, and xtlang is close enough to scheme for
# a preview (comments, strings, numbers, parens; no extempore parser exists
# in lumis's registry).
#
# `*.zshrc` already covers `~/.zshrc`, since `*` matches the empty string. The
# bare `zshrc`/`zshenv` are this repo's own copies, which carry no leading dot.
lang=""
case "$file" in
*.mdx | *.markdown | *.mdown | *.mkd) lang="markdown" ;;
*.zsh | *.zshrc | *.zshenv | zshrc | zshenv) lang="zsh" ;;
*.jsonc) lang="json" ;;
*.xtm) lang="scheme" ;;
esac

fallback() {
    # bat comes from mise (see mise/config.toml), so it's `bat` on both
    # platforms rather than Debian's `batcat`. Plain cat is the floor: an
    # unhighlighted preview beats an empty one.
    if command -v bat >/dev/null 2>&1; then
        bat --color=always --style=plain --paging=never -- "$file" 2>/dev/null
    else
        cat -- "$file" 2>/dev/null
    fi
    exit 0
}

command -v lumis >/dev/null 2>&1 || fallback

# Truncate into a scratch file that keeps the original name, so the extension
# still drives language selection.
src="$file"
tmp=""
if [[ "$(wc -l <"$file" 2>/dev/null || echo 0)" -gt "$MAX_LINES" ]]; then
    tmp="$(mktemp -d)"
    trap 'rm -rf "$tmp"' EXIT
    src="$tmp/$(basename -- "$file")"
    head -n "$MAX_LINES" -- "$file" >"$src" 2>/dev/null || fallback
fi

# Buffered rather than streamed, so a lumis failure (e.g. a parser cache miss
# with no network) can still fall back to bat instead of committing a partial
# preview.
if [[ -n "$lang" ]]; then
    out="$(lumis highlight --language "$lang" --theme "$THEME" "$src" 2>/dev/null)"
else
    out="$(lumis highlight --theme "$THEME" "$src" 2>/dev/null)"
fi

[[ -n "$out" ]] || fallback

printf '%s\n' "$out"

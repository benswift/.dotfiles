#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = ["psutil", "rich"]
# ///

# ty: ignore[unresolved-import]

import os
import re
import select
import signal
import subprocess
import sys
import termios
import time
import tty
from datetime import datetime

import psutil
from rich.console import Console, Group
from rich.live import Live
from rich.style import Style
from rich.table import Table
from rich.text import Text

MOCHA = {
    "fg": Style(color="#cdd6f4"),
    "bg4": Style(color="#a6adc8"),
    "bg4_dim": Style(color="#a6adc8", dim=True),
    "orange": Style(color="#fab387", bold=True),
    "blue": Style(color="#89b4fa", bold=True),
    "purple": Style(color="#cba6f7", bold=True),
    "green": Style(color="#a6e3a1"),
    "aqua": Style(color="#94e2d5"),
    "yellow": Style(color="#f9e2af"),
    "yellow_bold": Style(color="#f9e2af", bold=True),
    "red": Style(color="#f38ba8", bold=True),
    "dim": Style(dim=True),
}

AGENT_STYLES = {
    "claude": MOCHA["orange"],
    "codex": MOCHA["blue"],
    "gemini": MOCHA["purple"],
}

STRAY_PATTERNS = [
    ("chrome-hl", r"chrome-headless-shell"),
    ("agent-browser", r"agent-browser/.*daemon"),
    ("chromedriver", r"chromedriver"),
    ("playwright", r"playwright.*run-server"),
]

LISTENER_NAMES = {"extempore"}

CPU_HOG_THRESHOLD = 5.0
MAX_CPU_HOGS = 8

HOME = os.path.expanduser("~")

STATE_NORMAL = "normal"
STATE_ENTERING = "entering"
STATE_CONFIRMING = "confirming"

_cpu_primed = False


def fmt_elapsed(create_time: float) -> str:
    elapsed = int(time.time() - create_time)
    if elapsed < 0:
        elapsed = 0
    days, remainder = divmod(elapsed, 86400)
    hours, remainder = divmod(remainder, 3600)
    mins = remainder // 60
    out = ""
    if days > 0:
        out += f"{days}d"
    if hours > 0:
        out += f"{hours}h"
    out += f"{mins}m"
    return out


def shorten_path(path: str) -> str:
    if path.startswith(HOME):
        return "~" + path[len(HOME):]
    return path


def cmd_basename(p: psutil.Process) -> str:
    try:
        cmdline = p.cmdline()
        if cmdline:
            return os.path.basename(cmdline[0])
    except (psutil.NoSuchProcess, psutil.AccessDenied, psutil.ZombieProcess):
        pass
    return ""


def safe_cwd(p: psutil.Process) -> str:
    try:
        return shorten_path(p.cwd())
    except (psutil.NoSuchProcess, psutil.AccessDenied, psutil.ZombieProcess):
        return ""


def collect_processes() -> dict:
    global _cpu_primed
    if not _cpu_primed:
        for p in psutil.process_iter():
            try:
                p.cpu_percent()
            except (psutil.NoSuchProcess, psutil.AccessDenied, psutil.ZombieProcess):
                continue
        time.sleep(0.5)
        _cpu_primed = True

    agents: list[dict] = []
    strays: list[dict] = []
    cpu_hogs: list[dict] = []
    mail_clients: list[dict] = []
    servers: list[dict] = []

    for p in psutil.process_iter(["pid", "ppid"]):
        try:
            with p.oneshot():
                name = cmd_basename(p)
                display_name = name or p.name()
                pid = str(p.pid)
                cpu = p.cpu_percent()
                cpu_str = f"{cpu:.1f}"
                mem_str = f"{p.memory_percent():.1f}"
                elapsed = fmt_elapsed(p.create_time())

                if name in AGENT_STYLES:
                    agents.append({
                        "agent": name, "pid": pid, "cpu": cpu_str,
                        "mem": mem_str, "elapsed": elapsed, "cwd": safe_cwd(p),
                    })

                if name == "neomutt":
                    mail_clients.append({
                        "pid": pid, "cpu": cpu_str, "mem": mem_str,
                        "elapsed": elapsed, "cwd": safe_cwd(p),
                    })

                try:
                    cmdline_str = " ".join(p.cmdline())
                except (psutil.NoSuchProcess, psutil.AccessDenied, psutil.ZombieProcess):
                    cmdline_str = ""
                if cmdline_str:
                    for label, pattern in STRAY_PATTERNS:
                        if re.search(pattern, cmdline_str):
                            ppid = p.ppid()
                            strays.append({
                                "label": label, "pid": pid,
                                "cpu": cpu_str, "mem": mem_str,
                                "elapsed": elapsed,
                                "status": "orphaned" if ppid == 1 else f"ppid={ppid}",
                            })
                            break

                if cpu >= CPU_HOG_THRESHOLD:
                    cpu_hogs.append({
                        "name": display_name[:20], "pid": pid,
                        "cpu": cpu, "mem": mem_str, "elapsed": elapsed,
                        "cwd": safe_cwd(p),
                    })

                try:
                    conns = p.net_connections(kind="tcp")
                except (psutil.NoSuchProcess, psutil.AccessDenied, psutil.ZombieProcess):
                    conns = []
                if conns:
                    if display_name.lower() in LISTENER_NAMES:
                        ports = [c.laddr.port for c in conns if c.status == "LISTEN"]
                    else:
                        ports = [c.laddr.port for c in conns if c.status == "LISTEN" and 3000 <= c.laddr.port <= 9999]
                    if ports:
                        servers.append({
                            "cmd": display_name[:12], "pid": pid,
                            "port": str(ports[0]), "cpu": cpu_str,
                            "mem": mem_str, "elapsed": elapsed,
                            "cwd": safe_cwd(p),
                        })
        except (psutil.NoSuchProcess, psutil.AccessDenied, psutil.ZombieProcess):
            continue

    cpu_hogs.sort(key=lambda h: h["cpu"], reverse=True)
    return {
        "agents": agents,
        "strays": strays,
        "cpu_hogs": cpu_hogs[:MAX_CPU_HOGS],
        "mail_clients": mail_clients,
        "servers": servers,
    }


def lookup_pid(data: dict, pid_str: str) -> tuple[int, str] | None:
    try:
        pid = int(pid_str)
    except ValueError:
        return None
    for item in data["agents"]:
        if item["pid"] == pid_str:
            return (pid, item["agent"])
    for item in data["mail_clients"]:
        if item["pid"] == pid_str:
            return (pid, "neomutt")
    for item in data["strays"]:
        if item["pid"] == pid_str:
            return (pid, item["label"])
    for item in data["cpu_hogs"]:
        if item["pid"] == pid_str:
            return (pid, item["name"])
    for item in data["servers"]:
        if item["pid"] == pid_str:
            return (pid, item["cmd"])
    return None


def kill_process(pid: int) -> str:
    try:
        cmdline = psutil.Process(pid).cmdline()
    except (psutil.NoSuchProcess, psutil.AccessDenied, psutil.ZombieProcess):
        cmdline = []

    if cmdline and os.path.basename(cmdline[0]) == "zellij" and "--server" in cmdline:
        idx = cmdline.index("--server")
        if idx + 1 < len(cmdline):
            session_name = os.path.basename(cmdline[idx + 1])
            try:
                result = subprocess.run(
                    ["zellij", "kill-session", session_name],
                    capture_output=True, text=True, timeout=5,
                )
                if result.returncode == 0:
                    return f"zellij kill-session {session_name}"
                err = result.stderr.strip() or result.stdout.strip() or "unknown error"
                return f"zellij kill-session failed: {err}"
            except (subprocess.TimeoutExpired, FileNotFoundError) as e:
                return f"zellij kill-session error: {e}"

    try:
        os.kill(pid, signal.SIGTERM)
        return f"sent SIGTERM to PID {pid}"
    except ProcessLookupError:
        return f"PID {pid} already gone"
    except PermissionError:
        return f"permission denied to kill PID {pid}"


def build_display(data: dict, state: str = STATE_NORMAL, input_buf: str = "",
                  target: tuple[int, str] | None = None, message: str = "") -> Group:
    now = datetime.now().strftime("%H:%M:%S")
    header = Text()
    header.append("lsagents", style=Style(color="#cdd6f4", bold=True))
    header.append("  ")
    header.append(now, style=MOCHA["yellow"])
    header.append("\n")

    agents = data["agents"]
    strays = data["strays"]
    cpu_hogs = data["cpu_hogs"]
    mail_clients = data["mail_clients"]
    servers = data["servers"]

    agent_table = Table(
        show_header=True,
        show_edge=False,
        show_lines=False,
        box=None,
        padding=(0, 1),
        header_style=MOCHA["bg4"],
    )
    agent_table.add_column("AGENT", min_width=8, style=MOCHA["fg"])
    agent_table.add_column("PID", justify="right", min_width=6, style=MOCHA["fg"])
    agent_table.add_column("%CPU", justify="right", min_width=5, style=MOCHA["fg"])
    agent_table.add_column("%MEM", justify="right", min_width=5, style=MOCHA["fg"])
    agent_table.add_column("ELAPSED", justify="right", min_width=9, style=MOCHA["fg"])
    agent_table.add_column("CWD", style=MOCHA["aqua"])

    for a in agents:
        style = AGENT_STYLES[a["agent"]]
        agent_table.add_row(
            Text(a["agent"], style=style),
            a["pid"], a["cpu"], a["mem"], a["elapsed"], a["cwd"],
        )
    if not agents:
        agent_table.add_row(
            Text("(no agents running)", style=MOCHA["dim"]),
            "", "", "", "", "",
        )

    stray_table = Table(
        show_header=True,
        show_edge=False,
        show_lines=False,
        box=None,
        padding=(0, 1),
        header_style=MOCHA["bg4"],
    )
    stray_table.add_column("STRAY", min_width=16, style=MOCHA["fg"])
    stray_table.add_column("PID", justify="right", min_width=6, style=MOCHA["fg"])
    stray_table.add_column("%CPU", justify="right", min_width=5, style=MOCHA["fg"])
    stray_table.add_column("%MEM", justify="right", min_width=5, style=MOCHA["fg"])
    stray_table.add_column("ELAPSED", justify="right", min_width=9, style=MOCHA["fg"])
    stray_table.add_column("STATUS", style=MOCHA["dim"])

    for s in strays:
        stray_table.add_row(
            Text(s["label"], style=MOCHA["yellow_bold"]),
            s["pid"], s["cpu"], s["mem"], s["elapsed"], s["status"],
        )
    if not strays:
        stray_table.add_row(
            Text("(no stray processes)", style=MOCHA["dim"]),
            "", "", "", "", "",
        )

    hog_table = Table(
        show_header=True,
        show_edge=False,
        show_lines=False,
        box=None,
        padding=(0, 1),
        header_style=MOCHA["bg4"],
    )
    hog_table.add_column("CPU HOG", min_width=16, style=MOCHA["fg"])
    hog_table.add_column("PID", justify="right", min_width=6, style=MOCHA["fg"])
    hog_table.add_column("%CPU", justify="right", min_width=6, style=MOCHA["fg"])
    hog_table.add_column("%MEM", justify="right", min_width=5, style=MOCHA["fg"])
    hog_table.add_column("ELAPSED", justify="right", min_width=9, style=MOCHA["fg"])
    hog_table.add_column("CWD", style=MOCHA["aqua"])

    for h in cpu_hogs:
        cpu_style = MOCHA["red"] if h["cpu"] >= 50 else MOCHA["yellow_bold"]
        hog_table.add_row(
            Text(h["name"], style=cpu_style),
            h["pid"], f"{h['cpu']:.1f}", h["mem"], h["elapsed"], h["cwd"],
        )
    if not cpu_hogs:
        hog_table.add_row(
            Text("(no cpu hogs)", style=MOCHA["dim"]),
            "", "", "", "", "",
        )

    mail_table = Table(
        show_header=True,
        show_edge=False,
        show_lines=False,
        box=None,
        padding=(0, 1),
        header_style=MOCHA["bg4"],
    )
    mail_table.add_column("MAIL", min_width=8, style=MOCHA["fg"])
    mail_table.add_column("PID", justify="right", min_width=6, style=MOCHA["fg"])
    mail_table.add_column("%CPU", justify="right", min_width=5, style=MOCHA["fg"])
    mail_table.add_column("%MEM", justify="right", min_width=5, style=MOCHA["fg"])
    mail_table.add_column("ELAPSED", justify="right", min_width=9, style=MOCHA["fg"])
    mail_table.add_column("CWD", style=MOCHA["aqua"])

    for m in mail_clients:
        mail_table.add_row(
            Text("neomutt", style=MOCHA["green"]),
            m["pid"], m["cpu"], m["mem"], m["elapsed"], m["cwd"],
        )
    if not mail_clients:
        mail_table.add_row(
            Text("(no mail clients)", style=MOCHA["dim"]),
            "", "", "", "", "",
        )

    server_table = Table(
        show_header=True,
        show_edge=False,
        show_lines=False,
        box=None,
        padding=(0, 1),
        header_style=MOCHA["bg4"],
    )
    server_table.add_column("SERVER", min_width=12, style=MOCHA["fg"])
    server_table.add_column("PID", justify="right", min_width=6, style=MOCHA["fg"])
    server_table.add_column("PORT", justify="right", min_width=5, style=MOCHA["fg"])
    server_table.add_column("%CPU", justify="right", min_width=5, style=MOCHA["fg"])
    server_table.add_column("%MEM", justify="right", min_width=5, style=MOCHA["fg"])
    server_table.add_column("ELAPSED", justify="right", min_width=9, style=MOCHA["fg"])
    server_table.add_column("CWD", style=MOCHA["aqua"])

    for s in servers:
        server_table.add_row(
            Text(s["cmd"], style=MOCHA["red"]),
            s["pid"], s["port"], s["cpu"], s["mem"], s["elapsed"], s["cwd"],
        )
    if not servers:
        server_table.add_row(
            Text("(no dev servers running)", style=MOCHA["dim"]),
            "", "", "", "", "", "",
        )

    footer = Text()
    stray_count_style = MOCHA["yellow"] if strays else MOCHA["green"]
    hog_count_style = MOCHA["red"] if cpu_hogs else MOCHA["green"]
    footer.append(str(len(agents)), style=MOCHA["green"])
    footer.append(" agent(s), ", style=MOCHA["dim"])
    footer.append(str(len(mail_clients)), style=MOCHA["green"])
    footer.append(" mail, ", style=MOCHA["dim"])
    footer.append(str(len(servers)), style=MOCHA["green"])
    footer.append(" server(s), ", style=MOCHA["dim"])
    footer.append(str(len(strays)), style=stray_count_style)
    footer.append(" stray(s), ", style=MOCHA["dim"])
    footer.append(str(len(cpu_hogs)), style=hog_count_style)
    footer.append(" cpu hog(s)", style=MOCHA["dim"])
    footer.append("\n")

    if state == STATE_ENTERING:
        footer.append("kill PID: ", style=MOCHA["yellow_bold"])
        footer.append(input_buf, style=MOCHA["fg"])
        footer.append("\u258f", style=MOCHA["yellow"])
        footer.append("    (enter=confirm, esc=cancel)", style=MOCHA["dim"])
    elif state == STATE_CONFIRMING and target is not None:
        pid, label = target
        footer.append(f"kill {label} (PID {pid})? ", style=MOCHA["red"])
        footer.append("[y/N]", style=MOCHA["yellow_bold"])
    else:
        footer.append("q quit  \u2022  k kill-by-pid", style=MOCHA["dim"])

    if message:
        footer.append("  \u2022  ", style=MOCHA["dim"])
        footer.append(message, style=MOCHA["aqua"])

    return Group(header, agent_table, Text(), mail_table, Text(), stray_table, Text(), hog_table, Text(), server_table, Text(), footer)


def main() -> None:
    args = sys.argv[1:]
    if any(a in ("-h", "--help") for a in args):
        print("Usage: lsagents [--once]")
        print()
        print("Monitor running AI coding agents and dev servers.")
        print()
        print("Options:")
        print("  -1, --once    Print once and exit (no live refresh)")
        print()
        print("Interactive keys:")
        print("  q, ctrl-c     Quit")
        print("  k             Kill a listed process by PID (zellij-aware)")
        sys.exit(0)

    once = any(a in ("-1", "--once") for a in args)
    console = Console()

    if once or not sys.stdin.isatty():
        console.print(build_display(collect_processes()))
        return

    fd = sys.stdin.fileno()
    old_settings = termios.tcgetattr(fd)

    state = STATE_NORMAL
    input_buf = ""
    target: tuple[int, str] | None = None
    message = ""
    data = collect_processes()

    try:
        tty.setcbreak(fd)
        with Live(
            build_display(data, state, input_buf, target, message),
            console=console,
            auto_refresh=False,
            screen=True,
        ) as live:
            while True:
                live.update(build_display(data, state, input_buf, target, message))
                live.refresh()
                ready, _, _ = select.select([sys.stdin], [], [], 2)

                if not ready:
                    data = collect_processes()
                    if state == STATE_NORMAL:
                        message = ""
                    continue

                key = sys.stdin.read(1)

                if state == STATE_NORMAL:
                    if key in ("q", "\x03"):
                        break
                    if key == "k":
                        state = STATE_ENTERING
                        input_buf = ""
                        message = ""
                elif state == STATE_ENTERING:
                    if key == "\x03":
                        break
                    if key == "\x1b":
                        state = STATE_NORMAL
                        input_buf = ""
                    elif key in ("\r", "\n"):
                        result = lookup_pid(data, input_buf)
                        if result:
                            target = result
                            state = STATE_CONFIRMING
                            input_buf = ""
                        else:
                            message = f"no such PID in view: {input_buf}"
                            state = STATE_NORMAL
                            input_buf = ""
                    elif key == "\x7f":
                        input_buf = input_buf[:-1]
                    elif key.isdigit():
                        input_buf += key
                elif state == STATE_CONFIRMING:
                    if key == "\x03":
                        break
                    if key in ("y", "Y") and target is not None:
                        pid, _ = target
                        message = kill_process(pid)
                        state = STATE_NORMAL
                        target = None
                        data = collect_processes()
                    elif key in ("n", "N", "\x1b"):
                        state = STATE_NORMAL
                        target = None
    except KeyboardInterrupt:
        pass
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)


if __name__ == "__main__":
    main()

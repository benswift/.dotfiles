#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = [
#   "msal",
#   "httpx",
#   "typer",
# ]
# ///
# sharepoint-dl --- download a file from a OneDrive/SharePoint *sharing link*.
#
# Solves the "someone shared a OneDrive/SharePoint link with me and I want the
# bytes" case that rclone can't do --- rclone only enumerates drives you own,
# not items shared with you. We encode the sharing URL into a Microsoft Graph
# share-id and pull it via /shares/{id}/driveItem, following the file's
# pre-authenticated downloadUrl.
#
# Auth is a one-time device-code login against the ANU tenant (delegated
# Files.Read.All + Sites.Read.All). The refresh token is cached 0600 under
# ~/.cache/sharepoint-dl/, so later runs are non-interactive until it expires.
#
# You must supply your own Azure AD application (client) id --- ANU's tenant
# won't service the obvious Microsoft first-party public clients for these
# scopes: the Graph CLI Tools app (14d82eec-...) isn't provisioned in the
# directory (AADSTS700016), and the Azure CLI app (04b07795-...) is provisioned
# but isn't preauthorised to request Files/Sites scopes from Graph
# (AADSTS65002). rclone hits the same wall and tells you to do the same thing:
# register a single-tenant app once, then point this at it.
#
# First-time setup (https://entra.microsoft.com -> App registrations):
#   1. New registration; single-tenant; no redirect URI. Copy the client id.
#   2. Authentication -> "Allow public client flows" = Yes (enables device code).
#   3. API permissions -> Microsoft Graph -> Delegated -> Files.Read.All and
#      Sites.Read.All (both user-consentable; no client secret needed).
#   4. export SHAREPOINT_DL_CLIENT_ID=<client id>  (e.g. in mise config.local).
#
# Usage:
#   sharepoint-dl 'https://anu365-my.sharepoint.com/:w:/g/personal/.../IQA...'
#   sharepoint-dl '<url>' -o report.docx        # explicit output path
#   sharepoint-dl '<url>' -o ~/Downloads        # a directory keeps the server name
#   sharepoint-dl --login                       # force a fresh interactive login
#   sharepoint-dl --logout                      # clear the cached token

from __future__ import annotations

import base64
from pathlib import Path

import httpx
import msal
import typer

app = typer.Typer(add_completion=False)

# Default to the ANU tenant by its verified domain (override with --tenant or
# SHAREPOINT_DL_TENANT). The client id has no sane default --- see header.
DEFAULT_TENANT = "anu.edu.au"
SCOPES = ["Files.Read.All", "Sites.Read.All"]

CACHE_DIR = Path.home() / ".cache" / "sharepoint-dl"
CACHE_FILE = CACHE_DIR / "token_cache.json"
GRAPH = "https://graph.microsoft.com/v1.0"


def _load_cache() -> msal.SerializableTokenCache:
    cache = msal.SerializableTokenCache()
    if CACHE_FILE.exists():
        cache.deserialize(CACHE_FILE.read_text())
    return cache


def _save_cache(cache: msal.SerializableTokenCache) -> None:
    if cache.has_state_changed:
        CACHE_DIR.mkdir(parents=True, exist_ok=True)
        CACHE_FILE.write_text(cache.serialize())
        CACHE_FILE.chmod(0o600)


def _acquire_token(client_id: str, tenant: str, *, force_login: bool) -> str:
    cache = _load_cache()
    authority = f"https://login.microsoftonline.com/{tenant}"
    client = msal.PublicClientApplication(client_id, authority=authority, token_cache=cache)

    result: dict | None = None
    if not force_login:
        accounts = client.get_accounts()
        if accounts:
            result = client.acquire_token_silent(SCOPES, account=accounts[0])

    if result is None:
        flow = client.initiate_device_flow(scopes=SCOPES)
        if "user_code" not in flow:
            raise RuntimeError(f"could not start device flow: {flow.get('error_description', flow)}")
        typer.secho(flow["message"], fg=typer.colors.CYAN, err=True)
        result = client.acquire_token_by_device_flow(flow)

    _save_cache(cache)

    if not result or "access_token" not in result:
        detail = result.get("error_description", result) if result else "no result"
        raise RuntimeError(f"token acquisition failed: {detail}")
    return result["access_token"]


def _share_id(url: str) -> str:
    # base64url, strip padding, prepend "u!" --- the Graph sharing-URL recipe.
    encoded = base64.urlsafe_b64encode(url.encode()).decode().rstrip("=")
    return f"u!{encoded}"


def _stream_to(client: httpx.Client, url: str, dest: Path, headers: dict[str, str] | None) -> None:
    with client.stream("GET", url, headers=headers, timeout=None, follow_redirects=True) as resp:
        resp.raise_for_status()
        with dest.open("wb") as fh:
            for chunk in resp.iter_bytes():
                fh.write(chunk)


@app.command()
def main(
    url: str | None = typer.Argument(None, help="OneDrive/SharePoint sharing link"),
    output: Path | None = typer.Option(None, "--output", "-o", help="Output file or directory"),
    client_id: str | None = typer.Option(
        None, "--client-id", envvar="SHAREPOINT_DL_CLIENT_ID",
        help="Azure AD app (client) id (register your own; see header)",
    ),
    tenant: str = typer.Option(
        DEFAULT_TENANT, "--tenant", envvar="SHAREPOINT_DL_TENANT",
        help="Tenant id or verified domain",
    ),
    login: bool = typer.Option(False, "--login", help="Force a fresh interactive login"),
    logout: bool = typer.Option(False, "--logout", help="Clear the cached token and exit"),
) -> None:
    """Download a file from a OneDrive/SharePoint sharing link via Microsoft Graph."""
    if logout:
        CACHE_FILE.unlink(missing_ok=True)
        typer.secho("Cleared cached token.", fg=typer.colors.GREEN, err=True)
        raise typer.Exit()

    if not url:
        raise typer.BadParameter("a sharing URL is required (or pass --logout)")
    if not client_id:
        raise typer.BadParameter(
            "no client id --- register an Azure AD app and set "
            "SHAREPOINT_DL_CLIENT_ID or pass --client-id (see script header)"
        )

    token = _acquire_token(client_id, tenant, force_login=login)
    headers = {"Authorization": f"Bearer {token}"}
    share_id = _share_id(url)

    with httpx.Client() as http:
        meta = http.get(
            f"{GRAPH}/shares/{share_id}/driveItem",
            params={"select": "id,name,size,@microsoft.graph.downloadUrl"},
            headers=headers,
            timeout=30,
        )
        if meta.status_code in (401, 403):
            typer.secho(
                "Access denied. Confirm you signed in as the account the link was "
                "shared with, and that the link is still valid.",
                fg=typer.colors.RED,
                err=True,
            )
        meta.raise_for_status()
        item = meta.json()

        name = item["name"]
        dest = output or Path(name)
        if dest.is_dir():
            dest = dest / name

        size = item.get("size", "?")
        typer.secho(f"Downloading {name} ({size} bytes) -> {dest}", err=True)

        download_url = item.get("@microsoft.graph.downloadUrl")
        if download_url:
            # Pre-authenticated short-lived URL; send no auth header.
            _stream_to(http, download_url, dest, headers=None)
        else:
            # Fallback: /content 302-redirects to a temp download URL.
            _stream_to(http, f"{GRAPH}/shares/{share_id}/driveItem/content", dest, headers=headers)

    typer.secho(f"Saved {dest}", fg=typer.colors.GREEN, err=True)


if __name__ == "__main__":
    app()

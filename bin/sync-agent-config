#!/usr/bin/env bash
#
# Synchronise AI-agent configuration that cannot be represented as plain
# dotfile symlinks, such as Claude plugin installation and Codex skill links.
#
set -euo pipefail

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/.dotfiles}"
UPDATE_CLAUDE=false

source "$DOTFILES_DIR/lib/log.sh"

usage() {
    cat <<EOF
Usage: sync-agent-config [--update-claude]

Options:
  --update-claude   Pull Claude marketplaces and refresh installed plugins
  -h, --help        Show this help message
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
    --update-claude)
        UPDATE_CLAUDE=true
        shift
        ;;
    -h | --help)
        usage
        exit 0
        ;;
    *)
        echo "Unknown option: $1" >&2
        usage >&2
        exit 1
        ;;
    esac
done

sync_claude_plugins() {
    local settings="$DOTFILES_DIR/claude/settings.json"

    if ! command -v claude &>/dev/null; then
        warn "claude not installed --- skipping Claude plugin sync"
        return
    fi
    if ! command -v jq &>/dev/null; then
        warn "jq not installed --- skipping Claude plugin sync"
        return
    fi
    if [[ ! -f "$settings" ]]; then
        warn "Claude settings missing at $settings"
        return
    fi

    info "Synchronising Claude plugins..."
    # Build one `marketplace add` spec per entry: GitHub repos pin a ref with
    # @ref, plain git URLs with #ref (package marketplaces pin release tags).
    jq -r '.extraKnownMarketplaces // {} | to_entries[] | .value.source |
        if .repo then .repo + (if .ref then "@" + .ref else "" end)
        else .url + (if .ref then "#" + .ref else "" end) end' "$settings" |
        xargs -P 4 -I {} claude plugin marketplace add {} >/dev/null 2>&1 || true
    jq -r '.enabledPlugins // {} | to_entries[] | select(.value) | .key' "$settings" |
        xargs -P 4 -I {} claude plugin install --scope user {} >/dev/null 2>&1 || true

    if [[ "$UPDATE_CLAUDE" == "true" ]]; then
        claude plugin marketplace update >/dev/null 2>&1 || true
        claude plugin list --json 2>/dev/null |
            jq -r '.[] | select(.enabled) | "\(.id) \(.scope)"' |
            xargs -P 8 -L 1 sh -c 'claude plugin update --scope "$2" "$1" >/dev/null 2>&1' _ || true
    fi
}

sync_codex_skills() {
    local claude_skills="$HOME/.claude/plugins/marketplaces/ben/skills"
    local codex_skills="$HOME/.codex/skills"
    local codex_parent
    codex_parent="$(dirname "$codex_skills")"

    if [[ ! -d "$claude_skills" ]]; then
        warn "ben marketplace skills missing at $claude_skills"
        return
    fi

    mkdir -p "$codex_parent"

    if [[ -L "$codex_skills" ]]; then
        local link_target
        link_target="$(readlink "$codex_skills")"
        if [[ "$link_target" == "$claude_skills" ]]; then
            local tmp_skills="$codex_parent/skills.tmp.$$"
            mkdir -p "$tmp_skills"
            if [[ -d "$claude_skills/.system" ]]; then
                mv "$claude_skills/.system" "$tmp_skills/.system"
            fi
            rm "$codex_skills"
            mv "$tmp_skills" "$codex_skills"
        else
            warn "$codex_skills is a symlink to $link_target, leaving it alone"
            return
        fi
    elif [[ -e "$codex_skills" && ! -d "$codex_skills" ]]; then
        warn "$codex_skills exists but is not a directory"
        return
    else
        mkdir -p "$codex_skills"
    fi

    if [[ -d "$claude_skills/.system" ]]; then
        if [[ ! -e "$codex_skills/.system" ]]; then
            mv "$claude_skills/.system" "$codex_skills/.system"
        else
            local backup="$codex_parent/skills.system-from-claude.$(date +%Y%m%d%H%M%S)"
            mv "$claude_skills/.system" "$backup"
            warn "Moved duplicate Claude .system skills to $backup"
        fi
    fi

    local skill name dest existing
    for skill in "$claude_skills"/*; do
        [[ -d "$skill" ]] || continue
        name="$(basename "$skill")"
        [[ "$name" == .* ]] && continue
        dest="$codex_skills/$name"
        if [[ -L "$dest" ]]; then
            ln -sfn "$skill" "$dest"
        elif [[ -e "$dest" ]]; then
            warn "Codex skill $dest already exists and is not a symlink"
        else
            ln -s "$skill" "$dest"
        fi
    done

    for existing in "$codex_skills"/*; do
        [[ -L "$existing" ]] || continue
        local target
        target="$(readlink "$existing")"
        if [[ "$target" == "$claude_skills"/* && ! -e "$existing" ]]; then
            rm "$existing"
        fi
    done

    info "Synchronised Codex personal skills from $claude_skills"
}

sync_claude_plugins
# sync_codex_skills intentionally not called --- Codex is unused at the moment.
# Restore the call to re-link ~/.codex/skills from the ben marketplace clone.

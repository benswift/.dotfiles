#!/usr/bin/env bash
#
# flash-voyager --- build and flash ZSA Voyager firmware from an Oryx layout,
# with the per-key thumb tap/hold fix applied.
#
# Oryx exposes "Hold On Other Key Press" and "Tap Flow" only as global
# switches. This script fetches a layout's Oryx source, appends
# voyager/thumb-fix.c (per-key callbacks for the thumb dual-function keys),
# compiles it against ZSA's QMK fork, and flashes it. Oryx stays the source
# of truth for the layout; the fix is re-applied on every build, so the two
# never drift.
#
# See voyager/README.md for setup and usage.
#
set -euo pipefail

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/.dotfiles}"
SNIPPET="$DOTFILES_DIR/voyager/thumb-fix.c"
CACHE_DIR="$HOME/.cache/flash-voyager"
CACHED_ZIP="$CACHE_DIR/source.zip"
KEYMAP="ben"
ZSA_FORK="zsa/qmk_firmware"
ZSA_BRANCH="${ZSA_BRANCH:-firmware25}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

info() { echo -e "${GREEN}[flash-voyager]${NC} $1"; }
warn() { echo -e "${YELLOW}[flash-voyager]${NC} $1"; }
err()  { echo -e "${RED}[flash-voyager]${NC} $1" >&2; }
die()  { err "$1"; exit 1; }

usage() {
    cat <<'EOF'
Usage: flash-voyager [OPTIONS] [SOURCE]

Build and flash ZSA Voyager firmware from an Oryx layout, with the per-key
thumb tap/hold fix (voyager/thumb-fix.c) applied on top.

SOURCE   Oryx "Download Source" URL, or a path to the downloaded .zip.
         Omit to reuse the source from the previous run.

Options:
  --compile-only   Build the firmware but do not flash it
  --setup          Install the QMK toolchain and ZSA fork, then exit
  -h, --help       Show this help

Typical use --- edit the layout in Oryx, click Compile, copy the
"Download Source" link, then:

  flash-voyager 'https://oryx.zsa.io/source/XXXXXX'
EOF
}

do_setup() {
    info "One-time QMK toolchain setup."
    if command -v qmk &>/dev/null; then
        info "qmk already installed."
    elif command -v brew &>/dev/null; then
        info "Installing qmk (brew install qmk/qmk/qmk)..."
        # The qmk formula pulls its ARM/AVR toolchains from these
        # third-party taps; brew will not add them automatically.
        brew tap osx-cross/arm
        brew tap osx-cross/avr
        brew install qmk/qmk/qmk
    else
        die "Install the qmk CLI first --- see https://docs.qmk.fm/#/newbs_getting_started"
    fi
    info "Cloning ZSA's QMK fork ($ZSA_FORK, branch $ZSA_BRANCH) to ~/qmk_firmware."
    info "This pulls roughly 1 GB --- it will take a few minutes."
    qmk setup "$ZSA_FORK" -b "$ZSA_BRANCH" -y
    qmk doctor || warn "qmk doctor flagged issues --- review its output above."
    info "Setup complete. Now run: flash-voyager <oryx-source-url-or-zip>"
}

COMPILE_ONLY=false
SOURCE=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --setup)        do_setup; exit 0 ;;
        --compile-only) COMPILE_ONLY=true; shift ;;
        -h | --help)    usage; exit 0 ;;
        -*)             die "Unknown option: $1 (see --help)" ;;
        *)              SOURCE="$1"; shift ;;
    esac
done

# --- toolchain --------------------------------------------------------------
command -v qmk &>/dev/null || die "qmk not found. Run: flash-voyager --setup"
[[ -f "$SNIPPET" ]] || die "Thumb-fix snippet missing: $SNIPPET"

QMK_HOME="$(qmk config user.qmk_home 2>/dev/null | cut -d= -f2)"
[[ -n "$QMK_HOME" && "$QMK_HOME" != "None" ]] || QMK_HOME="$HOME/qmk_firmware"
[[ -d "$QMK_HOME" ]] || die "QMK firmware not found at $QMK_HOME. Run: flash-voyager --setup"

if [[ -d "$QMK_HOME/keyboards/voyager" ]]; then
    KEYBOARD="voyager"
elif [[ -d "$QMK_HOME/keyboards/zsa/voyager" ]]; then
    KEYBOARD="zsa/voyager"
else
    die "Voyager keyboard not found under $QMK_HOME/keyboards."
fi

# --- resolve the Oryx source ------------------------------------------------
mkdir -p "$CACHE_DIR"
if [[ -n "$SOURCE" ]]; then
    if [[ "$SOURCE" == http*://* ]]; then
        info "Downloading source: $SOURCE"
        curl -fsSL --max-time 60 -o "$CACHED_ZIP" "$SOURCE" || die "Download failed."
    elif [[ -f "$SOURCE" ]]; then
        info "Using source zip: $SOURCE"
        cp "$SOURCE" "$CACHED_ZIP"
    else
        die "SOURCE is neither a URL nor an existing file: $SOURCE"
    fi
else
    [[ -f "$CACHED_ZIP" ]] || die "No cached source. Pass an Oryx URL or .zip path."
    warn "Reusing cached source --- pass a new URL/zip if you have edited the layout."
fi
file -b "$CACHED_ZIP" | grep -qi 'zip archive' || die "Source is not a zip (bad URL?)."

# --- stage the layout into the QMK tree -------------------------------------
TMP="$(mktemp -d)"
trap 'rm -rf "$TMP"' EXIT
unzip -oq "$CACHED_ZIP" -d "$TMP"

KEYMAP_C="$(find "$TMP" -name keymap.c -print -quit)"
[[ -n "$KEYMAP_C" ]] || die "No keymap.c inside the source zip."
SRC_DIR="$(dirname "$KEYMAP_C")"

KEYMAP_DIR="$QMK_HOME/keyboards/$KEYBOARD/keymaps/$KEYMAP"
rm -rf "$KEYMAP_DIR"
mkdir -p "$KEYMAP_DIR"
# Copy the whole Oryx source folder. keymap.json must come across too: it
# declares the zsa community module, without which the build fails on a
# missing rgb_matrix_kb.inc.
cp -R "$SRC_DIR"/* "$KEYMAP_DIR/"
[[ -f "$KEYMAP_DIR/keymap.c" ]] || die "Staging failed --- keymap.c not copied."

# --- check the thumb keycodes still match thumb-fix.c -----------------------
for kc in 'MT(MOD_LSFT, KC_BSPC)' 'LT(1, KC_SPACE)'; do
    grep -qF "$kc" "$KEYMAP_DIR/keymap.c" \
        || warn "Layout no longer has '$kc' --- thumb-fix.c may need updating."
done

# --- apply the thumb fix ----------------------------------------------------
{ printf '\n\n'; cat "$SNIPPET"; } >> "$KEYMAP_DIR/keymap.c"
info "Applied thumb-fix.c (keyboard: $KEYBOARD, keymap: $KEYMAP)."

# --- put the keg-only Homebrew cross-compilers on PATH ----------------------
# brew installs arm-none-eabi-gcc / avr-gcc keg-only (versioned formulae), so
# they are not on PATH by default; qmk compile needs to find them.
if command -v brew &>/dev/null; then
    brew_prefix="$(brew --prefix)"
    for keg in arm-none-eabi-gcc@8 arm-none-eabi-binutils avr-gcc@8 avr-binutils; do
        if [[ -d "$brew_prefix/opt/$keg/bin" ]]; then
            PATH="$brew_prefix/opt/$keg/bin:$PATH"
        fi
    done
    export PATH
fi

# --- compile ----------------------------------------------------------------
info "Compiling ($KEYBOARD:$KEYMAP)..."
qmk compile -kb "$KEYBOARD" -km "$KEYMAP"

KEYBOARD_FILESAFE="${KEYBOARD//\//_}"
FIRMWARE_BIN="$QMK_HOME/${KEYBOARD_FILESAFE}_${KEYMAP}.bin"
[[ -f "$FIRMWARE_BIN" ]] || die "Firmware not found at $FIRMWARE_BIN."

if [[ "$COMPILE_ONLY" == true ]]; then
    info "Built: $FIRMWARE_BIN"
    info "Re-run without --compile-only to flash."
    exit 0
fi

# --- flash via dfu-util -----------------------------------------------------
# qmk flash invokes dfu-util without disambiguating, but the Voyager exposes
# both its run-time DFU interface (194f:0108) and the bootloader (3297:0791)
# at once --- so qmk flash errors with "More than one DFU capable USB device
# found". Locate the bootloader by vid:pid and target it by serial instead.

BOOTLOADER_VIDPID="3297:0791"
BOOTLOADER_ADDR="0x08002000"

BOOTLOADER_SERIAL=$(dfu-util -l 2>/dev/null \
    | grep -F "[$BOOTLOADER_VIDPID]" \
    | head -1 \
    | sed -n 's/.*serial="\([^"]*\)".*/\1/p')

if [[ -z "$BOOTLOADER_SERIAL" ]]; then
    warn "Voyager bootloader (DFU $BOOTLOADER_VIDPID) not visible on USB."
    warn "Put the board into bootloader and re-run --- on the keyboard, tap"
    warn "TG(2) (top-outer-left), then QK_BOOT (top-outer-right); or press"
    warn "the reset button on the Voyager's top edge just before re-running."
    die "Aborting flash."
fi

info "Bootloader found (serial $BOOTLOADER_SERIAL). Flashing..."
dfu-util -S "$BOOTLOADER_SERIAL" -a 0 -s "${BOOTLOADER_ADDR}:leave" -D "$FIRMWARE_BIN"
info "Flashed. Board should reboot into the new firmware momentarily."

#!/usr/bin/env bash
# Send a Pushover notification.
# Reads message from stdin or --message. Title from --title.
# Optional --priority and --url.
#
# Credentials: PUSHOVER_TOKEN and PUSHOVER_USER_KEY env vars if set
# (typically declared in ~/.config/mise/config.local.toml on headless boxes),
# otherwise read from 1Password
# (op://Personal/pushover.net/{Claude Code app token,user key}).

set -euo pipefail

TITLE=""
MESSAGE=""
PRIORITY=""
URL=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --title) TITLE="$2"; shift 2 ;;
        --message) MESSAGE="$2"; shift 2 ;;
        --priority) PRIORITY="$2"; shift 2 ;;
        --url) URL="$2"; shift 2 ;;
        -h|--help)
            cat <<'EOF'
Usage:
  notify-pushover [--title TITLE] [--priority N] [--url URL] [--message MSG]
  echo "msg" | notify-pushover --title "Hello"

Reads message from stdin if --message is not provided.
EOF
            exit 0
            ;;
        *)
            echo "notify-pushover: unknown argument: $1" >&2
            exit 1
            ;;
    esac
done

if [[ -z "$MESSAGE" ]]; then
    MESSAGE=$(cat)
fi

if [[ -z "$MESSAGE" ]]; then
    echo "notify-pushover: no message provided" >&2
    exit 1
fi

TOKEN="${PUSHOVER_TOKEN:-}"
USER_KEY="${PUSHOVER_USER_KEY:-}"

if [[ -z "$TOKEN" || -z "$USER_KEY" ]]; then
    if ! command -v op >/dev/null 2>&1; then
        echo "notify-pushover: PUSHOVER_TOKEN/PUSHOVER_USER_KEY not set and 'op' not available" >&2
        exit 1
    fi
    [[ -z "$TOKEN" ]] && TOKEN=$(op read 'op://Personal/pushover.net/Claude Code app token')
    [[ -z "$USER_KEY" ]] && USER_KEY=$(op read 'op://Personal/pushover.net/user key')
fi

CURL_ARGS=(
    --silent --show-error --fail
    --max-time 10
    --form-string "token=$TOKEN"
    --form-string "user=$USER_KEY"
    --form-string "message=$MESSAGE"
)
[[ -n "$TITLE" ]] && CURL_ARGS+=(--form-string "title=$TITLE")
[[ -n "$PRIORITY" ]] && CURL_ARGS+=(--form-string "priority=$PRIORITY")
[[ -n "$URL" ]] && CURL_ARGS+=(--form-string "url=$URL")

curl "${CURL_ARGS[@]}" https://api.pushover.net/1/messages.json >/dev/null

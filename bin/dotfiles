#!/usr/bin/env bash
#
# Dotfiles management command
# Usage: dotfiles <command>
#
set -euo pipefail

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/.dotfiles}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

pass=0
fail=0
warn=0

check_pass() { echo -e "  ${GREEN}✓${NC} $1"; ((pass++)) || true; }
check_fail() { echo -e "  ${RED}✗${NC} $1"; ((fail++)) || true; }
check_warn() { echo -e "  ${YELLOW}⚠${NC} $1 ${CYAN}(optional)${NC}"; ((warn++)) || true; }
section() { echo -e "\n${CYAN}$1${NC}"; }

command_exists() { command -v "$1" &>/dev/null; }

symlink_valid() {
    local target="$1"
    [[ -L "$target" && -e "$target" ]]
}

check_shell() {
    if [[ "$SHELL" == *zsh ]]; then
        check_pass "zsh is login shell"
        return
    fi

    if ! command_exists zsh; then
        check_fail "zsh not installed"
        return
    fi

    local zsh_path
    zsh_path=$(command -v zsh)

    # An exec stanza in a login rc bridges to zsh when chsh isn't an option
    # (typical on LDAP-managed accounts where the user isn't in /etc/passwd).
    local rc
    for rc in "$HOME/.profile" "$HOME/.bash_profile" "$HOME/.bash_login"; do
        if [[ -f "$rc" ]] && grep -qE "exec[[:space:]]+.*zsh" "$rc"; then
            check_warn "login shell is $SHELL but $(basename "$rc") execs zsh"
            return
        fi
    done

    check_fail "zsh installed at $zsh_path but login shell is $SHELL"

    # Detect LDAP/SSSD account: present via NSS but absent from /etc/passwd.
    # In that case chsh fails with 'user does not exist' --- suggest the
    # exec workaround instead.
    if command_exists getent \
        && ! getent -s files passwd "$USER" >/dev/null 2>&1 \
        && getent passwd "$USER" >/dev/null 2>&1; then
        cat <<EOF
    Account is in LDAP/NSS (not /etc/passwd) --- chsh will fail locally.
    Append to ~/.profile:

      case \$- in
        *i*) [ -x $zsh_path ] && [ -z "\$ZSH_VERSION" ] && exec $zsh_path -l ;;
      esac

    Or ask sysadmin to set loginShell in LDAP.
EOF
    else
        echo "    Run: chsh -s $zsh_path"
    fi
}

check_core() {
    section "Checking core requirements..."

    check_shell

    # Homebrew (macOS only)
    if [[ "$OSTYPE" == darwin* ]]; then
        if command_exists brew; then
            local brew_prefix
            brew_prefix=$(brew --prefix)
            check_pass "Homebrew installed at $brew_prefix"
        else
            check_fail "Homebrew not installed"
        fi
    fi

    # mise
    if command_exists mise; then
        check_pass "mise installed"
    else
        check_fail "mise not installed"
    fi

    # git
    if command_exists git; then
        check_pass "git installed"
    else
        check_fail "git not installed"
    fi

    # zoxide
    if command_exists zoxide; then
        check_pass "zoxide installed"
    else
        check_fail "zoxide not installed"
    fi

    # 1Password CLI (backend for fnox; brew/apt install, not mise)
    if command_exists op; then
        check_pass "op (1Password CLI) installed"
    else
        check_fail "op (1Password CLI) not installed"
    fi
}

check_symlinks() {
    section "Checking symlinks..."

    local symlinks=(
        "$HOME/.zshrc:$DOTFILES_DIR/zshrc"
        "$HOME/.zshenv:$DOTFILES_DIR/zshenv"
        "$HOME/.gitconfig:$DOTFILES_DIR/gitconfig"
        "$HOME/.gitignore:$DOTFILES_DIR/gitignore"
        "$HOME/.tmux.conf:$DOTFILES_DIR/tmux.conf"
        "$HOME/.config/mise/config.toml:$DOTFILES_DIR/mise/config.toml"
        "$HOME/.config/fnox/config.toml:$DOTFILES_DIR/fnox/config.toml"
        "$HOME/.ssh/config:$DOTFILES_DIR/ssh_config"
        "$HOME/.claude/CLAUDE.md:$DOTFILES_DIR/claude/CLAUDE.md"
        "$HOME/.claude/settings.json:$DOTFILES_DIR/claude/settings.json"
        "$HOME/.codex/instructions.md:$DOTFILES_DIR/claude/CLAUDE.md"
        "$HOME/.codex/config.toml:$DOTFILES_DIR/codex/config.toml"
        "$HOME/.gemini/settings.json:$DOTFILES_DIR/gemini/settings.json"
    )

    for entry in "${symlinks[@]}"; do
        local target="${entry%%:*}"
        local expected="${entry##*:}"

        if [[ -L "$target" ]]; then
            local actual
            actual=$(readlink "$target")
            if [[ "$actual" == "$expected" ]]; then
                check_pass "$(basename "$target") → $(basename "$expected")"
            else
                check_fail "$(basename "$target") points to wrong target"
            fi
        elif [[ -e "$target" ]]; then
            check_fail "$(basename "$target") exists but is not a symlink"
        else
            check_fail "$(basename "$target") missing"
        fi
    done
}

check_tools() {
    section "Checking tools..."

    local required_tools=(helix:hx tmux)
    local optional_tools=(neomutt mu mbsync msmtp rclone fzf)

    for tool in "${required_tools[@]}"; do
        local name="${tool%%:*}"
        local cmd="${tool##*:}"
        if command_exists "$cmd"; then
            check_pass "$name"
        else
            check_fail "$name not installed"
        fi
    done

    for tool in "${optional_tools[@]}"; do
        if command_exists "$tool"; then
            check_pass "$tool"
        else
            check_warn "$tool not installed"
        fi
    done
}

check_mise_tools() {
    section "Checking mise-managed tools..."

    if ! command_exists mise; then
        check_fail "mise not available, skipping tool check"
        return
    fi

    local tools
    tools=$(mise list --current 2>/dev/null | awk '{print $1}' | sort -u || echo "")

    if [[ -z "$tools" ]]; then
        check_warn "no mise tools installed (run 'mise install')"
    else
        for tool in $tools; do
            check_pass "$tool"
        done
    fi
}

check_directories() {
    section "Checking directories..."

    local dirs=(
        "$HOME/.config/zed"
        "$HOME/.config/mise"
        "$HOME/.claude"
        "$HOME/.codex"
    )

    local optional_dirs=(
        "$HOME/Maildir"
        "$HOME/.config/neomutt"
        "$HOME/.config/ghostty"
    )

    for dir in "${dirs[@]}"; do
        if [[ -d "$dir" ]]; then
            check_pass "$(basename "$dir")/"
        else
            check_fail "$(basename "$dir")/ missing"
        fi
    done

    for dir in "${optional_dirs[@]}"; do
        if [[ -d "$dir" ]]; then
            check_pass "$(basename "$dir")/"
        else
            check_warn "$(basename "$dir")/ missing"
        fi
    done
}

check_secrets() {
    section "Checking fnox secrets..."

    # fnox is mise-managed, so it's not on PATH for a bash script unless mise
    # has been activated. Resolve via 'mise which' so the check works whether
    # or not the parent shell activated mise.
    local fnox_bin
    if command_exists fnox; then
        fnox_bin="fnox"
    elif command_exists mise && fnox_bin=$(mise which fnox 2>/dev/null); then
        :
    else
        check_fail "fnox not installed (run 'mise install')"
        return
    fi

    if ! command_exists op; then
        check_fail "op (1Password CLI) not installed --- secrets won't resolve"
        return
    fi

    # Run fnox check from the dotfiles dir so it picks up fnox.toml + the
    # global ~/.config/fnox/config.toml. Resolves every op:// reference.
    local output
    if output=$(cd "$DOTFILES_DIR" && "$fnox_bin" check 2>&1); then
        check_pass "all dotfiles secrets resolve"
    else
        check_fail "fnox check failed: $(echo "$output" | head -1)"
    fi
}

check_skill_yaml() {
    local skills_dir="$1"

    if ! command_exists python3 || ! python3 -c 'import yaml' 2>/dev/null; then
        check_warn "python3 + PyYAML not available, skipping skill YAML validation"
        return
    fi

    if python3 -c '
import sys, yaml
for path in sys.argv[1:]:
    with open(path) as f:
        text = f.read()
    if not text.startswith("---\n"):
        continue
    idx = text.find("\n---\n", 4)
    if idx == -1:
        raise SystemExit(f"{path}: missing closing front matter")
    yaml.safe_load(text[4:idx])
' "$skills_dir"/*/SKILL.md >/dev/null 2>&1; then
        check_pass "skill front matter parses"
    else
        check_fail "skill front matter has YAML errors"
    fi
}

check_agent_config() {
    section "Checking AI agent configuration..."

    local ben_skills="$HOME/.claude/plugins/marketplaces/ben/skills"
    local codex_skills="$HOME/.codex/skills"

    if command_exists claude; then
        check_pass "claude installed"
    else
        check_fail "claude not installed"
    fi

    if command_exists codex; then
        check_pass "codex installed"
    else
        check_fail "codex not installed"
    fi

    if [[ -d "$ben_skills" ]]; then
        check_pass "ben marketplace skills cloned"
        check_skill_yaml "$ben_skills"
        if [[ -d "$ben_skills/.system" ]]; then
            check_fail "Codex .system skills are inside ben marketplace clone"
        else
            check_pass "ben marketplace has no Codex .system skills"
        fi
    else
        check_fail "ben marketplace skills missing"
    fi

    if [[ -d "$codex_skills" && ! -L "$codex_skills" ]]; then
        check_pass "codex skills directory is local"
    elif [[ -L "$codex_skills" ]]; then
        check_fail "codex skills is a whole-directory symlink"
    else
        check_fail "codex skills directory missing"
    fi

    if [[ -L "$codex_skills/project-manager-backlog" && -e "$codex_skills/project-manager-backlog/SKILL.md" ]]; then
        check_pass "codex sees ben personal skills"
    else
        check_fail "codex personal skill links missing"
    fi

    if [[ -d "$codex_skills/.system" ]]; then
        check_pass "codex owns .system skills"
    else
        check_warn "codex .system skills not present yet"
    fi

    if [[ -f "$HOME/.agents/skills/agent-browser/SKILL.md" ]]; then
        check_pass "agent-browser skill installed for Codex"
    else
        check_warn "agent-browser skill not installed in ~/.agents"
    fi

    if command_exists claude && command_exists jq; then
        local plugins
        if plugins=$(claude plugin list --json 2>/dev/null) &&
            jq -e '.[] | select(.id == "ben@ben" and .enabled == true)' >/dev/null <<<"$plugins"; then
            check_pass "ben@ben Claude plugin enabled"
        else
            check_fail "ben@ben Claude plugin not enabled"
        fi
    else
        check_warn "claude or jq unavailable, skipping plugin status"
    fi
}

doctor() {
    echo ""
    echo "╔═══════════════════════════════════════╗"
    echo "║         Dotfiles Doctor               ║"
    echo "╚═══════════════════════════════════════╝"

    check_core
    check_symlinks
    check_tools
    check_mise_tools
    check_directories
    check_secrets
    check_agent_config

    echo ""
    section "Summary"
    echo -e "  ${GREEN}$pass passed${NC}, ${RED}$fail failed${NC}, ${YELLOW}$warn warnings${NC}"
    echo ""

    if [[ $fail -gt 0 ]]; then
        echo "Run '$DOTFILES_DIR/create_symlinks.sh' to fix symlinks"
        echo "Run '$DOTFILES_DIR/install.sh' for full setup"
        return 1
    fi
}

update() {
    echo "Updating dotfiles..."
    git -C "$DOTFILES_DIR" pull --rebase
    "$DOTFILES_DIR/create_symlinks.sh"
    "$DOTFILES_DIR/bin/sync-agent-config" --update-claude
    echo "Done!"
}

usage() {
    echo "Usage: dotfiles <command>"
    echo ""
    echo "Commands:"
    echo "  doctor    Check if everything is set up correctly"
    echo "  update    Pull latest changes and re-run symlinks"
    echo "  edit      Open dotfiles in editor"
    echo "  cd        Print dotfiles directory (use: cd \$(dotfiles cd))"
    echo ""
}

case "${1:-}" in
    doctor) doctor ;;
    update) update ;;
    edit)   "${EDITOR:-hx}" "$DOTFILES_DIR" ;;
    cd)     echo "$DOTFILES_DIR" ;;
    *)      usage ;;
esac

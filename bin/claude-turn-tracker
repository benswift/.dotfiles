#!/usr/bin/env bash
# Claude Code hook handler that sends Pushover notifications and records each
# agent's state for bin/zj-switch.
# Reads the hook payload (JSON) from stdin and dispatches by subcommand:
#   session-start  register the agent as idle      (SessionStart hook)
#   start          record turn-start time          (UserPromptSubmit hook)
#   stop           notify if turn ran >= threshold (Stop hook)
#   notify         agent wants attention           (Notification hook)
#   session-end    deregister the agent            (SessionEnd hook)
#
# Threshold defaults to 300s (5 min); override with CLAUDE_NOTIFY_THRESHOLD.
# Notifications are tagged "host:project" using $ZELLIJ_SESSION_NAME when
# running inside zellij, falling back to the cwd basename from the payload.
#
# Nothing here may fail loudly: a hook that exits non-zero surfaces as an
# error inside Claude Code, so every state write is best-effort.

set -euo pipefail

cmd="${1:-}"
threshold_seconds="${CLAUDE_NOTIFY_THRESHOLD:-300}"
stamp_dir="${TMPDIR:-/tmp}"
state_dir="${XDG_RUNTIME_DIR:-/tmp}/claude-agent-state"

input=$(cat)
sid=$(echo "$input" | jq -r '.session_id // empty')
[[ -n "$sid" ]] || exit 0

if [[ -n "${ZELLIJ_SESSION_NAME:-}" ]]; then
    proj="$ZELLIJ_SESSION_NAME"
else
    cwd=$(echo "$input" | jq -r '.cwd // empty')
    proj="${cwd##*/}"
    [[ -n "$proj" ]] || proj="?"
fi

host=$(hostname -s)
stamp_file="$stamp_dir/claude-turn-$sid"

# --- agent state, consumed by bin/zj-switch ---------------------------------
#
# Claude Code's own lifecycle hooks are the only honest source of "what is
# this agent doing". The alternative --- reading the pane's title or its
# screen --- infers state from a UI that changes without notice. One file per
# agent, filed under the zellij session that owns it.

# The pid of the claude process this hook was spawned from, stored alongside
# the state so zj-switch can discard entries whose agent was killed outright
# and never fired session-end.
claude_pid() {
    local p="$PPID" args
    while [[ -n "$p" && "$p" != 1 ]]; do
        args="$(ps -o args= -p "$p" 2>/dev/null)" || return 0
        [[ "$args" == claude* ]] && {
            printf '%s' "$p"
            return 0
        }
        p="$(ps -o ppid= -p "$p" 2>/dev/null | tr -d ' ')" || return 0
    done
}

write_state() {
    [[ -n "${ZELLIJ_SESSION_NAME:-}" ]] || return 0
    local dir="$state_dir/$ZELLIJ_SESSION_NAME"
    mkdir -p "$dir" 2>/dev/null || return 0
    printf '%s %s\n' "$1" "$(claude_pid)" >"$dir/$sid" 2>/dev/null || return 0
}

clear_state() {
    [[ -n "${ZELLIJ_SESSION_NAME:-}" ]] || return 0
    rm -f "$state_dir/$ZELLIJ_SESSION_NAME/$sid"
    rmdir "$state_dir/$ZELLIJ_SESSION_NAME" 2>/dev/null || true
}

# --- pane naming, but only while the agent is blocked ------------------------
#
# A zellij rename is sticky: it overrides every subsequent OSC title until
# undone. Claude Code sets an OSC title continuously --- an animated spinner
# plus the task in progress --- and that is strictly more informative than any
# state glyph we could substitute. So the title is taken over only once the
# agent has gone quiet and stopped saying anything, and handed straight back
# when work resumes. Zellij keeps tracking the program's title underneath, so
# undo-rename-pane restores whatever Claude Code most recently set.
#
# ZELLIJ_PANE_ID is exported into the pane and inherited by claude, so this
# targets the agent's own pane rather than whichever pane happens to be
# focused.
rename_pane() {
    [[ -n "${ZELLIJ_PANE_ID:-}" ]] || return 0
    command -v zellij &>/dev/null || return 0
    zellij action rename-pane --pane-id "$ZELLIJ_PANE_ID" "$1" &>/dev/null || return 0
}

restore_pane() {
    [[ -n "${ZELLIJ_PANE_ID:-}" ]] || return 0
    command -v zellij &>/dev/null || return 0
    zellij action undo-rename-pane --pane-id "$ZELLIJ_PANE_ID" &>/dev/null || return 0
}

case "$cmd" in
    session-start)
        write_state idle
        ;;
    session-end)
        restore_pane
        clear_state
        ;;
    notify)
        write_state blocked
        # Notification carries why it wants you (a permission request, or that
        # it's been waiting); prefer that over a generic marker.
        reason=$(echo "$input" | jq -r '.message // empty' | head -c 48)
        rename_pane "⚠ ${reason:-needs you}"
        ;;
    start)
        restore_pane
        write_state working
        date +%s > "$stamp_file"
        ;;
    stop)
        write_state idle
        [[ -f "$stamp_file" ]] || exit 0
        start=$(cat "$stamp_file")
        rm -f "$stamp_file"
        elapsed=$(( $(date +%s) - start ))
        (( elapsed >= threshold_seconds )) || exit 0
        minutes=$((elapsed / 60))
        seconds=$((elapsed % 60))
        msg=$(printf 'Turn finished in %dm %02ds' "$minutes" "$seconds")
        transcript=$(echo "$input" | jq -r '.transcript_path // empty')
        if [[ -n "$transcript" && -f "$transcript" ]]; then
            title=$(jq -r 'select(.type=="ai-title") | .aiTitle' "$transcript" 2>/dev/null | tail -n1)
            [[ -n "$title" ]] && msg="${msg}"$'\n'"${title}"
        fi
        echo "$msg" | notify-pushover --title "Claude done: $host:$proj" || true
        ;;
    *)
        echo "Usage: $(basename "$0") {session-start|start|stop|notify|session-end}" >&2
        exit 1
        ;;
esac

#!/usr/bin/env bash
# Claude Code hook handler that sends Pushover notifications.
# Reads the hook payload (JSON) from stdin and dispatches by subcommand:
#   start    record turn-start time              (UserPromptSubmit hook)
#   stop     notify if turn ran >= threshold     (Stop hook)
#   notify   forward an input-needed message     (Notification hook)
#
# Threshold defaults to 300s (5 min); override with CLAUDE_NOTIFY_THRESHOLD.
# Notifications are tagged "host:project" using $ZELLIJ_SESSION_NAME when
# running inside zellij, falling back to the cwd basename from the payload.

set -euo pipefail

cmd="${1:-}"
threshold_seconds="${CLAUDE_NOTIFY_THRESHOLD:-300}"
stamp_dir="${TMPDIR:-/tmp}"

input=$(cat)
sid=$(echo "$input" | jq -r '.session_id // empty')
[[ -n "$sid" ]] || exit 0

if [[ -n "${ZELLIJ_SESSION_NAME:-}" ]]; then
    proj="$ZELLIJ_SESSION_NAME"
else
    cwd=$(echo "$input" | jq -r '.cwd // empty')
    proj="${cwd##*/}"
    [[ -n "$proj" ]] || proj="?"
fi

host=$(hostname -s)
stamp_file="$stamp_dir/claude-turn-$sid"

case "$cmd" in
    start)
        date +%s > "$stamp_file"
        ;;
    stop)
        [[ -f "$stamp_file" ]] || exit 0
        start=$(cat "$stamp_file")
        rm -f "$stamp_file"
        elapsed=$(( $(date +%s) - start ))
        (( elapsed >= threshold_seconds )) || exit 0
        minutes=$((elapsed / 60))
        seconds=$((elapsed % 60))
        msg=$(printf 'Turn finished in %dm %02ds' "$minutes" "$seconds")
        echo "$msg" | notify-pushover --title "Claude done: $host:$proj" || true
        ;;
    notify)
        msg=$(echo "$input" | jq -r '.message // "Claude needs input"')
        echo "$msg" | notify-pushover --title "Claude input needed: $host:$proj" --priority 1 || true
        ;;
    *)
        echo "Usage: $(basename "$0") {start|stop|notify}" >&2
        exit 1
        ;;
esac

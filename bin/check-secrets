#!/usr/bin/env bash

set -euo pipefail

# Show help message
if [[ "${1:-}" == "-h" ]] || [[ "${1:-}" == "--help" ]]; then
    echo "Usage: check-secrets [-v|--verbose] [-h|--help]"
    echo ""
    echo "Run a gitleaks scan to check for secrets and sensitive data in a repository."
    echo "Scans the full git history plus any uncommitted changes. Known false"
    echo "positives can be suppressed via a .gitleaksignore file of fingerprints."
    echo ""
    echo "Options:"
    echo "  -v, --verbose   Show the matched secret fragments in the findings"
    echo "  -h, --help      Show this help message"
    echo ""
    echo "Must be run from within a git repository."
    exit 0
fi

# Parse command line arguments
VERBOSE=false
if [[ "${1:-}" == "-v" ]] || [[ "${1:-}" == "--verbose" ]]; then
    VERBOSE=true
fi

# Get the repository root
if ! repo_root=$(git rev-parse --show-toplevel 2>/dev/null); then
    echo "Error: not in a git repository"
    exit 1
fi

# Ensure required tooling is available (installed via mise, see mise/config.toml)
if ! command -v gitleaks >/dev/null 2>&1; then
    echo "Error: gitleaks not found on PATH."
    echo "Install it with: mise install gitleaks"
    exit 1
fi

GITLEAKS_ARGS=(--no-banner --exit-code 2)
[ "$VERBOSE" = true ] && GITLEAKS_ARGS+=(--verbose)

echo "Running gitleaks on: $repo_root"
echo "Checking for secrets and sensitive data..."
echo

# Scan the git history (committed secrets) and the uncommitted changes about
# to join it. Both are git-aware, so gitignored build junk (venvs, grammar
# sources, node_modules) never generates false positives --- unlike a bare
# filesystem scan, which walks everything. The trade-off: an untracked file is
# only scanned once staged. A non-zero exit means "found something", not
# "broke" --- so catch it rather than letting set -e abort the report below.
exit_code=0
echo "--- git history ---"
gitleaks git "${GITLEAKS_ARGS[@]}" "$repo_root" || exit_code=$?
echo
echo "--- uncommitted changes ---"
(cd "$repo_root" && gitleaks git --pre-commit "${GITLEAKS_ARGS[@]}") || exit_code=$?

if [ $exit_code -eq 0 ]; then
    echo
    echo "✓ No secrets detected"
elif [ $exit_code -eq 2 ]; then
    echo
    echo "⚠ Secrets or sensitive data may have been detected"
    echo "Please review the findings above and take appropriate action"
else
    echo
    echo "Error: gitleaks failed to run (exit $exit_code)"
fi

exit $exit_code

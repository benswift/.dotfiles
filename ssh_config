# Added by OrbStack: 'orb' SSH host for Linux machines
# This only works if it's at the top of ssh_config (before any Host blocks).
# Comment this line if you don't want it to be added again.
Include ~/.orbstack/ssh/config

Host *
  IgnoreUnknown UseKeychain
  AddKeysToAgent yes
  UseKeychain yes

# git remotes
Host github.com
  HostName github.com
  User git

Host gitlab.anu.edu.au
  HostName gitlab.anu.edu.au
  User git
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes

Host gitlab.comp.anu.edu.au
  HostName gitlab.comp.anu.edu.au
  User git
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes

# rpis on tailnet
Host panic-*
  User panic
  StrictHostKeyChecking no
  UserKnownHostsFile /dev/null

# cybersonic
# bulwark only accepts SSH from on-campus IPs, so off-campus machines hop via
# weddle (tailnet-reachable). The Match guard skips the ProxyJump when running
# on weddle itself --- otherwise ssh would tunnel through itself.
Match host bulwark exec "test $(hostname -s) != weddle"
  ProxyJump weddle

Host bulwark
  User u2548636
  Hostname bulwark.cecs.anu.edu.au
  IdentityFile ~/.ssh/cybersonic

Host cybersonic
  User u2548636
  Hostname cybersonic.gpu
  IdentityFile ~/.ssh/cybersonic
  ProxyJump bulwark

# weddle — tailnet jump host for bulwark (see the Match block above). FQDN so it
# always resolves through Tailscale, on any network.
Host weddle
  User ben
  Hostname weddle.tail2b9b56.ts.net
  HostKeyAlias weddle

# jetson orin — use the Tailscale MagicDNS FQDN so resolution always goes
# through Tailscale (works on any network), and never collides with the
# local LAN's `jetson-orin.uds.anu.edu.au` entry that points at the wired IP.
# HostKeyAlias keeps known_hosts stable across address changes.
Host jetson
  User jane
  Hostname jetson-orin.tail2b9b56.ts.net
  HostKeyAlias jetson-orin

# daysy — Ben's Mac on the tailnet. Tailscale owner shows as benswift@, but the
# macOS account is `ben`. MagicDNS FQDN resolves on any network; HostKeyAlias
# keeps known_hosts stable across address changes.
Host daysy
  User ben
  Hostname daysy.tail2b9b56.ts.net
  HostKeyAlias daysy

# strproxy
Host strproxy
  User u2548636
  Hostname strproxy.comp.anu.edu.au

# macOS: route through the 1Password SSH agent. Guarded so it's a no-op on Linux.
Match host * exec "uname -s | grep -q Darwin"
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

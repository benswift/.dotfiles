# Added by OrbStack: 'orb' SSH host for Linux machines
# This only works if it's at the top of ssh_config (before any Host blocks).
# Comment this line if you don't want it to be added again.
Include ~/.orbstack/ssh/config

Host *
  IgnoreUnknown UseKeychain
  AddKeysToAgent yes
  UseKeychain yes

# git remotes
Host github.com
  HostName github.com
  User git

Host gitlab.anu.edu.au
  HostName gitlab.anu.edu.au
  User git
  IdentityFile ~/.ssh/gitlab_anu
  IdentitiesOnly yes

Host gitlab.comp.anu.edu.au
  HostName gitlab.comp.anu.edu.au
  User git
  IdentityFile ~/.ssh/gitlab_anu
  IdentitiesOnly yes

# rpis on tailnet
Host panic-*
  User panic
  StrictHostKeyChecking no
  UserKnownHostsFile /dev/null

# cybersonic
Host bulwark
  User u2548636
  Hostname bulwark.cecs.anu.edu.au
  IdentityFile ~/.ssh/cybersonic

Host cybersonic
  User u2548636
  Hostname cybersonic.gpu
  IdentityFile ~/.ssh/cybersonic
  ProxyCommand ssh -q -A u2548636@bulwark.cecs.anu.edu.au nc -q0 %h %p

# cpu1
Host cpu1
  User benswift
  Hostname cpu1.cecs.anu.edu.au
  IdentityFile ~/.ssh/id_ed25519

Host cpu2
  User benswift
  Hostname cpu2.cecs.anu.edu.au
  IdentityFile ~/.ssh/id_ed25519

# strproxy
Host strproxy
  User u2548636
  Hostname strproxy.comp.anu.edu.au
  IdentityFile ~/.ssh/id_ed25519

# Azure
Host extempore-win
  User azureuser
  Hostname 68.218.107.86
  IdentityFile ~/.ssh/extempore_windows_vm

# macOS: route through the 1Password SSH agent. Guarded so it's a no-op on Linux.
Match host * exec "uname -s | grep -q Darwin"
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 365,
  "includeCoAuthoredBy": false,
  "permissions": {
    "defaultMode": "default"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.dotfiles/bin/claude-format",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.dotfiles/bin/claude-turn-tracker start"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.dotfiles/bin/claude-turn-tracker stop"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.dotfiles/bin/claude-turn-tracker notify"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.dotfiles/bin/claude-turn-tracker session-start"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.dotfiles/bin/claude-turn-tracker session-end"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.dotfiles/bin/claude-statusline"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": false,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": false,
    "agent-browser@agent-browser": true,
    "impeccable@impeccable": true,
    "ast-grep@ast-grep-marketplace": true,
    "modern-web-guidance@googlechrome": true,
    "ben@ben": true,
    "astro-theme-anu@astro-theme-anu": true
  },
  "extraKnownMarketplaces": {
    "ben": {
      "source": {
        "source": "github",
        "repo": "benswift/claude-plugin-personal"
      }
    },
    "impeccable": {
      "source": {
        "source": "github",
        "repo": "pbakaus/impeccable"
      }
    },
    "agent-browser": {
      "source": {
        "source": "github",
        "repo": "vercel-labs/agent-browser"
      }
    },
    "ast-grep-marketplace": {
      "source": {
        "source": "github",
        "repo": "ast-grep/agent-skill"
      }
    },
    "googlechrome": {
      "source": {
        "source": "github",
        "repo": "GoogleChrome/modern-web-guidance"
      }
    },
    "astro-theme-anu": {
      "source": {
        "source": "git",
        "url": "https://gitlab.anu.edu.au/u2548636/astro-theme-anu.git",
        "ref": "astro-theme-anu@v0.9.0"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "editorMode": "vim",
  "preferredNotifChannel": "ghostty",
  "agentPushNotifEnabled": true
}

{
  "parser-directories": ["~/.local/share/tree-sitter/grammars"],
  "theme": {
    "attribute": "#f9e2af",
    "comment": { "color": "#6c7086", "italic": true },
    "constant": "#fab387",
    "constant.builtin": "#fab387",
    "constructor": "#f9e2af",
    "embedded": "#cdd6f4",
    "escape": "#f5c2e7",
    "function": "#89b4fa",
    "function.builtin": "#89b4fa",
    "function.method": "#89b4fa",
    "keyword": "#cba6f7",
    "label": "#f5c2e7",
    "markup.bold": { "color": "#cdd6f4", "bold": true },
    "markup.heading": { "color": "#89b4fa", "bold": true },
    "markup.italic": { "color": "#cdd6f4", "italic": true },
    "markup.link.label": "#89b4fa",
    "markup.link.url": { "color": "#74c7ec", "underline": true },
    "markup.list": "#f5c2e7",
    "markup.quote": { "color": "#a6adc8", "italic": true },
    "markup.raw": "#a6e3a1",
    "markup.strikethrough": "#6c7086",
    "module": "#f9e2af",
    "number": "#fab387",
    "operator": "#89dceb",
    "property": "#94e2d5",
    "punctuation": "#9399b2",
    "punctuation.bracket": "#9399b2",
    "punctuation.delimiter": "#9399b2",
    "punctuation.special": "#f5c2e7",
    "string": "#a6e3a1",
    "string.escape": "#f5c2e7",
    "string.special": "#f5c2e7",
    "tag": "#89b4fa",
    "type": "#f9e2af",
    "type.builtin": "#f9e2af",
    "variable": "#cdd6f4",
    "variable.builtin": "#f38ba8",
    "variable.member": "#94e2d5",
    "variable.parameter": "#eba0ac"
  }
}

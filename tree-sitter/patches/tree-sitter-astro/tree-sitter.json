{
  "grammars": [
    {
      "name": "astro",
      "camelcase": "Astro",
      "scope": "source.astro",
      "path": ".",
      "file-types": ["astro"],
      "injection-regex": "^astro$",
      "highlights": ["queries/highlights.scm"],
      "injections": ["queries/injections.scm"]
    }
  ],
  "metadata": {
    "version": "0.0.1",
    "license": "MIT",
    "description": "Astro grammar for tree-sitter"
  },
  "bindings": {
    "c": false,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false
  }
}

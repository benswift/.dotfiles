{
  "grammars": [
    {
      "name": "typst",
      "camelcase": "Typst",
      "scope": "source.typst",
      "path": ".",
      "file-types": ["typ"],
      "injection-regex": "^typst$",
      "highlights": ["queries/typst/highlights.scm"],
      "injections": ["queries/typst/injections.scm"]
    }
  ],
  "metadata": { "version": "0.10.0", "license": "MIT" },
  "bindings": {
    "c": false,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false
  }
}
